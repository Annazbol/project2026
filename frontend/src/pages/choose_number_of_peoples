<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Выбор количества человек</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--tg-theme-bg-color, #ffffff);
            color: var(--tg-theme-text-color, #000000);
            padding: 20px;
            min-height: 100vh;
        }

        .container {
            max-width: 400px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            margin-bottom: 24px;
        }

        .header h1 {
            font-size: 24px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .subtitle {
            font-size: 14px;
            color: var(--tg-theme-hint-color, #8e8e93);
        }

        .booking-info {
            background-color: var(--tg-theme-secondary-bg-color, #f5f5f5);
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 24px;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid rgba(0, 0, 0, 0.05);
        }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-label {
            font-weight: 500;
            color: var(--tg-theme-hint-color, #8e8e93);
        }

        .info-value {
            font-weight: 600;
        }

        .loading-state {
            text-align: center;
            padding: 40px 20px;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border: 3px solid var(--tg-theme-hint-color, #e0e0e0);
            border-top-color: var(--tg-theme-button-color, #2481cc);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 16px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .error-state {
            text-align: center;
            padding: 40px 20px;
            color: #e34d4d;
        }

        .section-title {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 16px;
            font-weight: 600;
            font-size: 16px;
        }

        .hint {
            font-size: 12px;
            font-weight: normal;
            color: var(--tg-theme-hint-color, #8e8e93);
        }

        .options-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-bottom: 24px;
        }

        .option-btn {
            flex: 1;
            min-width: 80px;
            padding: 12px 16px;
            background-color: var(--tg-theme-secondary-bg-color, #f5f5f5);
            border: 1px solid transparent;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 500;
            color: var(--tg-theme-text-color, #000000);
            cursor: pointer;
            transition: all 0.2s ease;
            text-align: center;
        }

        .option-btn.selected {
            background-color: var(--tg-theme-button-color, #2481cc);
            border-color: var(--tg-theme-button-color, #2481cc);
            color: var(--tg-theme-button-text-color, #ffffff);
        }

        .warning-message {
            background-color: rgba(255, 193, 7, 0.1);
            border-left: 4px solid #ffc107;
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 24px;
            font-size: 14px;
            color: #ffc107;
        }

        .btn {
            width: 100%;
            padding: 14px 20px;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s ease;
        }

        .btn-primary {
            background-color: var(--tg-theme-button-color, #2481cc);
            color: var(--tg-theme-button-text-color, #ffffff);
        }

        .btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .btn-back {
            background-color: transparent;
            color: var(--tg-theme-link-color, #2481cc);
            margin-top: 16px;
        }

        .no-options {
            text-align: center;
            padding: 40px;
            color: var(--tg-theme-hint-color, #8e8e93);
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>Выбор количества человек</h1>
            <p class="subtitle">Выберите количество участников бронирования</p>
        </div>

        <div class="booking-info">
            <div class="info-row">
                <span class="info-label">Дата:</span>
                <span class="info-value" id="selectedDate">—</span>
            </div>
            <div class="info-row">
                <span class="info-label">Время:</span>
                <span class="info-value" id="selectedTime">—</span>
            </div>
            <div class="info-row">
                <span class="info-label">Корпус:</span>
                <span class="info-value" id="selectedBuilding">—</span>
            </div>
        </div>

        <div id="loadingState" class="loading-state">
            <div class="spinner"></div>
            <p>Загрузка доступных вариантов...</p>
        </div>

        <div id="errorState" class="error-state" style="display: none;">
            <p>⚠️ Не удалось загрузить доступные варианты</p>
            <button id="retryBtn" class="btn" style="background-color: var(--tg-theme-secondary-bg-color); margin-top: 12px;">Повторить</button>
        </div>

        <div id="formState" style="display: none;">
            <div class="section-title">
                <span>Доступные варианты</span>
                <span class="hint">на выбранное время</span>
            </div>
            
            <div id="availableOptions" class="options-grid"></div>

            <div id="warningMessage" class="warning-message" style="display: none;">
                <p>⚠️ На выбранное время доступны только указанные варианты</p>
            </div>

            <button id="submitBtn" class="btn btn-primary" disabled>Продолжить</button>
        </div>

        <button id="backBtn" class="btn btn-back">← Назад</button>
    </div>

    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script>
        const tg = window.Telegram.WebApp;
        tg.expand();

        const loadingState = document.getElementById('loadingState');
        const errorState = document.getElementById('errorState');
        const formState = document.getElementById('formState');
        const availableOptionsDiv = document.getElementById('availableOptions');
        const warningMessage = document.getElementById('warningMessage');
        const submitBtn = document.getElementById('submitBtn');
        const backBtn = document.getElementById('backBtn');
        const retryBtn = document.getElementById('retryBtn');

        let selectedPeopleCount = null;
        let availableOptions = [];

        let bookingContext = {
            date: null,
            timeStart: null,
            buildingId: null,
            buildingName: null
        };

        function getBookingContext() {
            const urlParams = new URLSearchParams(window.location.search);
            
            bookingContext = {
                date: urlParams.get('date') || localStorage.getItem('booking_date'),
                timeStart: urlParams.get('time') || localStorage.getItem('booking_time'),
                buildingId: urlParams.get('building_id') || localStorage.getItem('building_id'),
                buildingName: urlParams.get('building_name') || localStorage.getItem('building_name')
            };
            
            document.getElementById('selectedDate').textContent = bookingContext.date || 'Не выбрано';
            document.getElementById('selectedTime').textContent = bookingContext.timeStart || 'Не выбрано';
            document.getElementById('selectedBuilding').textContent = bookingContext.buildingName || 'Не выбран';
            
            return bookingContext.date && bookingContext.timeStart && bookingContext.buildingId;
        }

        async function fetchAvailableOptions() {
            try {
                loadingState.style.display = 'block';
                errorState.style.display = 'none';
                formState.style.display = 'none';
                
                const response = await fetch('/api/available-people-counts', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Telegram-Init-Data': tg.initData
                    },
                    body: JSON.stringify({
                        date: bookingContext.date,
                        time_start: bookingContext.timeStart,
                        building_id: bookingContext.buildingId
                    })
                });
                
                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
                
                const data = await response.json();
                
                if (data.success) {
                    availableOptions = data.available_counts || [];
                    if (data.warning) {
                        warningMessage.style.display = 'block';
                        warningMessage.querySelector('p').textContent = data.warning;
                    } else {
                        warningMessage.style.display = 'none';
                    }
                    renderOptions(availableOptions);
                    return true;
                } else {
                    throw new Error(data.error || 'Неизвестная ошибка');
                }
            } catch (error) {
                console.error('Ошибка:', error);
                loadingState.style.display = 'none';
                errorState.style.display = 'block';
                return false;
            }
        }

        function renderOptions(options) {
            loadingState.style.display = 'none';
            formState.style.display = 'block';
            
            if (!options || options.length === 0) {
                availableOptionsDiv.innerHTML = '<div class="no-options">На выбранное время нет доступных вариантов</div>';
                submitBtn.disabled = true;
                return;
            }
            
            availableOptionsDiv.innerHTML = '';
            
            options.forEach(count => {
                const button = document.createElement('button');
                button.className = 'option-btn';
                button.textContent = `${count} чел.`;
                button.dataset.count = count;
                
                button.addEventListener('click', () => {
                    document.querySelectorAll('.option-btn').forEach(btn => btn.classList.remove('selected'));
                    button.classList.add('selected');
                    selectedPeopleCount = count;
                    submitBtn.disabled = false;
                });
                
                availableOptionsDiv.appendChild(button);
            });
        }

        function submitSelection() {
            if (!selectedPeopleCount) {
                tg.showAlert('Пожалуйста, выберите количество человек');
                return;
            }
            
            tg.sendData(JSON.stringify({
                action: 'select_people_count',
                people_count: selectedPeopleCount,
                date: bookingContext.date,
                time_start: bookingContext.timeStart,
                building_id: bookingContext.buildingId
            }));
            
            tg.close();
        }

        function goBack() {
            tg.sendData(JSON.stringify({
                action: 'back',
                step: 'people_count'
            }));
            tg.close();
        }

        async function init() {
            tg.setHeaderColor('bg_color');
            tg.BackButton.show();
            tg.BackButton.onClick(() => goBack());
            
            if (!getBookingContext()) {
                loadingState.style.display = 'none';
                errorState.style.display = 'block';
                errorState.querySelector('p').textContent = '❌ Отсутствуют данные о бронировании';
                return;
            }
            
            await fetchAvailableOptions();
            
            submitBtn.addEventListener('click', submitSelection);
            backBtn.addEventListener('click', goBack);
            if (retryBtn) retryBtn.addEventListener('click', () => fetchAvailableOptions());
        }
        
        init();
    </script>
</body>
</html>
